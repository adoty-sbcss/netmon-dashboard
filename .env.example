# Copy to .env.local for local dev (Next.js auto-loads it; drizzle-kit reads via dotenv).
# NEVER commit a real .env / .env.local — they are gitignored.

# --- Database --------------------------------------------------------------
# Local dev points at a local Postgres; prod uses Azure Postgres Flexible Server.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/netmon_dashboard

# --- Auth -------------------------------------------------------------------
# Required. Signs the local-account session cookie (HMAC). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this invalidates every active session. In Azure, store in Key Vault.
AUTH_SECRET=

# --- OIDC sign-in (Google / Microsoft Entra) -------------------------------
# Optional. When a provider's id + secret are set, its sign-in button appears.
# Users must be pre-registered by email on /settings/users (the allowlist).
# Callback URIs to register with each provider:
#   <APP_ORIGIN>/api/auth/oidc/google/callback
#   <APP_ORIGIN>/api/auth/oidc/microsoft/callback
#
# Public origin used to build the callback URL. Pin it in prod so it can't drift
# (e.g. https://w2-sbcss-netmon-web.<env>.westus2.azurecontainerapps.io). If unset,
# it's derived from the request's x-forwarded-* headers.
# APP_ORIGIN=http://localhost:3000
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_MICROSOFT_ENTRA_ID_ID=
# AUTH_MICROSOFT_ENTRA_ID_SECRET=
# AUTH_MICROSOFT_ENTRA_ID_TENANT=common   # or your Directory (tenant) ID

# --- Ingestion (SFTP pull) -------------------------------------------------
# Configured from the admin UI (/settings/ingestion) and stored encrypted in the
# DB. These env vars are a fallback only (the old deploy-time path).
# SFTP_HOST=
# SFTP_PORT=22
# SFTP_USER=
# SFTP_PASSWORD=
# SFTP_BASE_DIR=/

# --- Azure (filled in at deploy time) --------------------------------------
# AZURE_STORAGE_ACCOUNT=
# AZURE_BLOB_CONTAINER=bundles

# --- AI analysis (docs/DESIGN.md §10) --------------------------------------
# PRIMARY config is now the in-app admin page: /settings/ai (keys encrypted at
# rest like the SFTP creds). These env vars are a FALLBACK only — used when a
# provider has no DB row yet. Each model column is independent; a provider with
# no key shows "not configured". The daily Job + the on-demand button read both.
#
# GPT — Azure OpenAI (in-tenant; uses your Azure credits):
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-10-21
#
# GPT — OpenAI direct (platform.openai.com; uses your org's API credits):
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_ORGANIZATION=        # optional
# OPENAI_PROJECT=             # optional
#
# Claude — Anthropic API (console.anthropic.com key; separate from a Claude
# subscription). Leave unset until a key is available.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
